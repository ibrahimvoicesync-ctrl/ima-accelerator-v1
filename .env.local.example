NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Discord WidgetBot (Resources > Community tab)
NEXT_PUBLIC_DISCORD_GUILD_ID=
NEXT_PUBLIC_DISCORD_CHANNEL_ID=

# Rebrandly — student referral short links
# Required: /api/referral-link registers each referral code as a Rebrandly link
# on the application.imaccelerator.com branded domain. All three vars are
# required. If any is missing the route returns 500.
#
#  REBRANDLY_API_KEY       — account API key (https://app.rebrandly.com/account/api-keys).
#                            Verify with: curl https://api.rebrandly.com/v1/account -H "apikey: $KEY"
#  REBRANDLY_WORKSPACE_ID  — id of the workspace owning the branded domain. Find with:
#                            curl https://api.rebrandly.com/v1/workspaces -H "apikey: $KEY"
#                            (use the "Main Workspace" id if the account has several).
#  REBRANDLY_DOMAIN_ID     — id of the application.imaccelerator.com branded domain. Find with:
#                            curl https://api.rebrandly.com/v1/domains -H "apikey: $KEY" -H "workspace: $WS"
REBRANDLY_API_KEY=
REBRANDLY_WORKSPACE_ID=
REBRANDLY_DOMAIN_ID=
